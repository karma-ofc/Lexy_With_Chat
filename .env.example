# Example environment variables for Lexy with Chat

# Main server
PORT=3000
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lexy

# Chat server
CHAT_PORT=3001
CHAT_DB_HOST=postgres
CHAT_DB_PORT=5432
CHAT_DB_USER=postgres
CHAT_DB_PASSWORD=postgres
CHAT_DB_NAME=chat

JWT_SECRET=replace_me_with_secure_value
